# Example Configuration File
# Copy this file to config.yaml and customize for your environment

server:
  host: "localhost"
  port: "8080"

database:
  host: "localhost"
  port: "5432"
  user: "postgres"
  password: "your_password_here"
  name: "users_db"
  sslmode: "disable"

jwt:
  secret: "your-super-secret-jwt-key-here"
  expiry_hours: 24 